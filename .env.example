# Optional app password for the dashboard login gate. Leave blank to disable it.
ADMIN_PASSWORD=

# Backend/runtime port (API + bundled frontend in Docker/production).
# Vite dev server stays on 8080.
PORT=3737

# Docker Compose uses PORT for both the in-container listener and published host port.
# Change PORT above if you want Docker to run on a different port.

# Optional frontend API override.
# Local dev (`yarn dev`) ignores VITE_API_URL and uses same-origin + Vite proxy.
# Use this only for production builds or advanced cross-origin setups.
# VITE_API_URL=http://localhost:3737

# Optional backend worker tuning
# Docker Compose defaults keep automatic monitoring and scheduler disabled at startup.
# Set both vars to 0 to enable automatic monitoring/scheduler jobs.
# DISCOGENIUS_DISABLE_MONITORING=0
# DISCOGENIUS_DISABLE_SCHEDULER=0
# DISCOGENIUS_DOWNLOAD_TIMEOUT_MS=7200000
# DISCOGENIUS_DOWNLOAD_IDLE_TIMEOUT_MS=600000
# DISCOGENIUS_DOWNLOAD_POLL_MS=2000
# DISCOGENIUS_SCHEDULER_POLL_MS=2000
