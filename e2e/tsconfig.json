{
    "compilerOptions": {
        "target": "ES2022",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "types": [
            "node",
            "@playwright/test"
        ],
        "esModuleInterop": true,
        "allowJs": false,
        "noEmit": true,
        "strict": false,
        "skipLibCheck": true
    },
    "include": [
        "./**/*.ts"
    ]
}